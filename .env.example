# ======================================
#  RMM Server Configuration
#  Copy this file to .env and edit values
# ======================================

# --- Database ---
POSTGRES_USER=rmm_user
POSTGRES_PASSWORD=rmm_password
POSTGRES_DB=rmm_db

# --- Agent Security ---
# This key must match what each deployed agent has in its config.json
AGENT_API_KEY=change-this-to-a-secure-key

# --- Dashboard Authentication ---
DASHBOARD_PASSWORD=change-this-password
JWT_SECRET=generate-a-long-random-string-here
